---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Hero from './Hero.astro';
import StatBlock from './StatBlock.astro';
import HowWeWork from './HowWeWork.astro';
import CTA from './CTA.astro';
import ProcessDiagram from './ProcessDiagram.astro';
import type { Segment } from './ProcessDiagram.astro';
import { pathFor, type Lang } from '../../i18n/routes';
import { useTranslations } from '../../i18n/utils';

interface Props {
  entry: CollectionEntry<'segments'>;
  solutions: CollectionEntry<'solutions'>[];
  lang: Lang;
}

const { entry, solutions, lang } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(entry);
---

<Hero
  eyebrow={t('nav.segmentsLabel')}
  title={entry.data.title}
  subtitle={entry.data.excerpt}
  image={entry.data.heroImage}
  imageAlt={entry.data.heroImageAlt}
  ctaLabel={t('common.getInTouch')}
  ctaHref={pathFor('contact', lang)}
/>

<StatBlock stats={entry.data.stats} heading={t('segment.stats.heading')} />

<section class="bg-neutral-50">
  <div class="mx-auto max-w-3xl px-6 py-16 lg:px-8">
    <div class="prose prose-neutral max-w-none
      prose-headings:font-heading prose-headings:text-brand-navy-950
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-3
      prose-p:text-neutral-700 prose-p:leading-relaxed
      prose-li:text-neutral-700
      prose-strong:text-brand-navy-900
      prose-a:text-brand-navy-700 prose-a:font-medium hover:prose-a:text-brand-navy-950">
      <Content />
    </div>
  </div>
</section>

<ProcessDiagram segment={entry.data.segmentKey as Segment} lang={lang} />

<HowWeWork lang={lang} />

{solutions.length > 0 && (
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <h2 class="font-heading text-2xl font-bold text-brand-navy-950">{t('segment.solutions.heading')}</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {solutions.map((s) => (
          <a href={pathFor('solutions', lang)} class="block rounded-2xl border border-neutral-200 bg-neutral-50 p-6 hover:border-brand-navy-700 hover:shadow-md transition-all">
            <h3 class="font-heading text-lg font-bold text-brand-navy-950">{s.data.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-neutral-600">{s.data.excerpt}</p>
            <p class="mt-4 text-xs font-semibold text-brand-navy-700">{t('common.learnMore')} →</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<CTA
  heading={t('segment.cta.heading')}
  ctaLabel={t('common.contactUs')}
  ctaHref={pathFor('contact', lang)}
/>
