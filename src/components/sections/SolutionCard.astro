---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  title: string;
  excerpt: string;
  image?: ImageMetadata;
  imageAlt?: string;
  usedInLabel?: string;
  usedIn?: string[];
  processStep?: string;
}

const { title, excerpt, image, imageAlt, usedInLabel, usedIn = [], processStep } = Astro.props;
---

<article class="grid gap-6 rounded-2xl border border-neutral-200 bg-white p-6 shadow-sm sm:grid-cols-5 sm:items-center">
  <div class="sm:col-span-2">
    <div class="aspect-[4/3] overflow-hidden rounded-xl bg-brand-navy-900">
      {image && <Image src={image} alt={imageAlt ?? ''} widths={[300, 600]} sizes="30vw" class="h-full w-full object-cover" />}
    </div>
  </div>
  <div class="sm:col-span-3">
    {processStep && (
      <span class="inline-block rounded-full bg-brand-green-200 px-3 py-1 text-xs font-semibold text-brand-green-700">{processStep}</span>
    )}
    <h3 class="mt-3 font-heading text-xl font-bold text-brand-navy-950">{title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-neutral-600">{excerpt}</p>
    {usedIn.length > 0 && (
      <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-neutral-400">
        {usedInLabel} <span class="text-brand-navy-700">{usedIn.join(' · ')}</span>
      </p>
    )}
  </div>
</article>
