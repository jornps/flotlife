---
import Button from '../ui/Button.astro';

interface Props {
  heading: string;
  body?: string;
  ctaLabel: string;
  ctaHref: string;
}

const { heading, body, ctaLabel, ctaHref } = Astro.props;
---

<section class="bg-brand-green-700">
  <div class="mx-auto max-w-4xl px-6 py-16 text-center lg:px-8">
    <h2 class="font-heading text-3xl font-bold text-white">{heading}</h2>
    {body && <p class="mx-auto mt-4 max-w-2xl text-white/85">{body}</p>}
    <div class="mt-8">
      <Button href={ctaHref} variant="secondary">{ctaLabel}</Button>
    </div>
  </div>
</section>
