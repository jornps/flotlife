---
import { pathFor, type PageKey, type Lang } from '../../i18n/routes';
import { useTranslations } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  pageKey: PageKey;
}

const { lang, pageKey } = Astro.props;
const t = useTranslations(lang);

const segmentLinks: { key: PageKey; label: string }[] = [
  { key: 'havbruk',  label: t('nav.havbruk') },
  { key: 'industri', label: t('nav.industri') },
  { key: 'kommunal', label: t('nav.kommunal') },
  { key: 'maritim',  label: t('nav.maritim') },
];
---

<header style="position:sticky;top:0;z-index:50;background:rgba(255,255,255,.92);backdrop-filter:blur(10px);border-bottom:1px solid #e3e9ee;">
  <div style="max-width:1200px;margin:0 auto;padding:0 40px;height:72px;display:flex;align-items:center;justify-content:space-between;">

    <!-- Brand -->
    <a href={pathFor('home', lang)} style="display:flex;align-items:center;gap:9px;font-weight:800;font-size:19px;color:#003764;letter-spacing:-.3px;text-decoration:none;">
      <svg width="22" height="26" viewBox="0 0 22 26" fill="none">
        <path d="M11 1C11 1 20 12 20 18.5C20 23 16 25 11 25C6 25 2 23 2 18.5C2 12 11 1 11 1Z" fill="#3CB4E6"/>
        <path d="M7 19a4 4 0 0 0 4 3" stroke="#fff" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      FlotLife <small style="font-weight:600;color:#3CB4E6;">Nordic</small>
    </a>

    <!-- Desktop nav -->
    <nav class="fl-navlinks" aria-label="Main">
      <a href={pathFor('solutions', lang)}>{t('nav.solutions')}</a>
      <div class="fl-seg-wrap">
        <button class="fl-seg-btn" type="button">
          {t('nav.segmentsLabel')}
          <svg width="12" height="8" viewBox="0 0 12 8" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </button>
        <div class="fl-seg-drop">
          {segmentLinks.map(({ key, label }) => (
            <a href={pathFor(key, lang)}>{label}</a>
          ))}
        </div>
      </div>
      <a href={pathFor('sustainability', lang)}>{t('nav.sustainability')}</a>
      <a href={pathFor('about', lang)}>{t('nav.about')}</a>
    </nav>

    <!-- Right side -->
    <div class="fl-navright">
      <LanguageSwitcher lang={lang} pageKey={pageKey} class="fl-lang" />
      <a href={pathFor('contact', lang)} class="fl-contact-btn">{t('nav.contact')}</a>
    </div>

    <!-- Mobile hamburger -->
    <button id="fl-menu-toggle" class="fl-ham" aria-label="Toggle menu" aria-expanded="false" aria-controls="fl-mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="fl-mobile-menu" class="fl-mobile hidden" aria-label="Mobile">
    <a href={pathFor('solutions', lang)}>{t('nav.solutions')}</a>
    {segmentLinks.map(({ key, label }) => (
      <a href={pathFor(key, lang)} style="padding-left:1.5rem;">{label}</a>
    ))}
    <a href={pathFor('sustainability', lang)}>{t('nav.sustainability')}</a>
    <a href={pathFor('about', lang)}>{t('nav.about')}</a>
    <a href={pathFor('contact', lang)} style="color:#3CB4E6;font-weight:700;">{t('nav.contact')}</a>
    <div style="border-top:1px solid #e3e9ee;padding-top:.75rem;margin-top:.25rem;">
      <LanguageSwitcher lang={lang} pageKey={pageKey} class="fl-lang" />
    </div>
  </nav>
</header>

<style>
.fl-navlinks {
  display: flex;
  align-items: center;
  gap: 30px;
  font-size: 15px;
  font-weight: 600;
  color: #33434f;
}
.fl-navlinks a { text-decoration: none; transition: color .16s; }
.fl-navlinks a:hover { color: #003764; }

.fl-seg-wrap { position: relative; }
.fl-seg-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  background: none;
  border: none;
  font: inherit;
  font-size: 15px;
  font-weight: 600;
  color: #33434f;
  cursor: pointer;
  padding: 0;
  transition: color .16s;
}
.fl-seg-btn:hover { color: #003764; }
.fl-seg-drop {
  display: none;
  position: absolute;
  top: 100%;
  left: -10px;
  min-width: 190px;
  background: #fff;
  border: 1px solid #e3e9ee;
  border-radius: 6px;
  box-shadow: 0 8px 24px rgba(0,40,80,.10);
  padding: 10px 6px 6px;
  flex-direction: column;
  z-index: 100;
}
.fl-seg-drop.open { display: flex; }
.fl-seg-drop a {
  display: block;
  padding: 8px 12px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 500;
  color: #33434f;
  text-decoration: none;
  white-space: nowrap;
  transition: background .12s, color .12s;
}
.fl-seg-drop a:hover { background: #eef3f6; color: #003764; }

.fl-navright {
  display: flex;
  align-items: center;
  gap: 20px;
}
:global(.fl-lang) {
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: #5b6b78;
  border: 1px solid #e3e9ee;
  border-radius: 2px;
  padding: 5px 9px;
  text-decoration: none;
  transition: border-color .16s, color .16s;
}
:global(.fl-lang:hover) { border-color: #003764; color: #003764; }
.fl-contact-btn {
  display: inline-flex;
  align-items: center;
  height: 42px;
  padding: 0 20px;
  background: #3CB4E6;
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  border-radius: 2px;
  text-decoration: none;
  transition: filter .16s;
}
.fl-contact-btn:hover { filter: brightness(.93); }

.fl-ham {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}
.fl-ham span { display: block; width: 22px; height: 2px; background: #003764; border-radius: 1px; }

.fl-mobile {
  flex-direction: column;
  border-top: 1px solid #e3e9ee;
  padding: 12px 40px 16px;
}
.fl-mobile a {
  display: block;
  padding: 9px 0;
  font-size: 15px;
  font-weight: 600;
  color: #33434f;
  text-decoration: none;
  border-bottom: 1px solid #f0f4f7;
}
.fl-mobile.hidden { display: none; }

@media (max-width: 900px) {
  .fl-navlinks { display: none; }
  .fl-navright  { display: none; }
  .fl-ham       { display: flex; }
  .fl-mobile:not(.hidden) { display: flex; }
}
</style>

<script>
// Mobile hamburger
const toggle = document.getElementById('fl-menu-toggle');
const menu   = document.getElementById('fl-mobile-menu');
toggle?.addEventListener('click', () => {
  const open = menu?.classList.toggle('hidden');
  toggle.setAttribute('aria-expanded', String(!open));
});

// Segments dropdown — click-based so there's no hover gap dead zone
const segBtn  = document.querySelector('.fl-seg-btn') as HTMLElement | null;
const segDrop = document.querySelector('.fl-seg-drop') as HTMLElement | null;
segBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  const isOpen = segDrop?.classList.toggle('open');
  segBtn.setAttribute('aria-expanded', String(!!isOpen));
});
document.addEventListener('click', () => {
  segDrop?.classList.remove('open');
  segBtn?.setAttribute('aria-expanded', 'false');
});
segDrop?.addEventListener('click', (e) => e.stopPropagation());
</script>
