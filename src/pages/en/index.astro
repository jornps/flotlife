---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import ProcessSteps from '../../components/sections/ProcessSteps.astro';
import StatBlock from '../../components/sections/StatBlock.astro';
import SegmentCard from '../../components/sections/SegmentCard.astro';
import CTA from '../../components/sections/CTA.astro';
import { pathFor } from '../../i18n/routes';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const segments = (await getCollection('segments', (s) => s.data.lang === lang)).sort(
  (a, b) => a.data.order - b.data.order,
);

const stats = [
  { value: '400,000 t', label: 'Sludge generated by Norwegian aquaculture every year' },
  { value: 'up to 7x', label: 'Sludge volume reduction with dewatering' },
  { value: '4', label: 'Nordic segments served with one technology platform' },
];

const processSteps = [
  { label: 'Capture', description: 'Early capture of particles, feces, biosolids and suspended solids, before they spread and get harder to manage.' },
  { label: 'Separate & Concentrate', description: 'Efficient separation and concentration of organic material out of the water stream.' },
  { label: 'Dewater', description: 'Mechanical dewatering that cuts volume and turns sludge into something transportable.' },
  { label: 'Polish', description: 'Water polishing that lowers organic load and makes discharge safer to answer for.' },
];
---

<BaseLayout lang={lang} pageKey="home" title="FlotLife Nordic — Water Treatment for Aquaculture, Industry, Municipal & Maritime" description="FlotLife Nordic brings proven dissolved air flotation and sludge dewatering technology to aquaculture, industry, municipalities and maritime operations across the Nordics.">
  <Hero
    eyebrow={t('home.hero.eyebrow')}
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    ctaLabel={t('home.hero.cta')}
    ctaHref={pathFor('contact', lang)}
    ctaSecondaryLabel={t('home.hero.ctaSecondary')}
    ctaSecondaryHref={pathFor('solutions', lang)}
    image={segments[0]?.data.heroImage}
    imageAlt={segments[0]?.data.heroImageAlt}
  />

  <ProcessSteps
    heading="One process line, built to fit your site"
    intro="Every FlotLife Nordic system is built from the same four modules — configured differently depending on what's in your water and what needs to happen to it."
    steps={processSteps}
  />

  <section class="bg-neutral-50">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-brand-navy-950">{t('home.segments.heading')}</h2>
      <p class="mt-3 max-w-2xl text-neutral-600">{t('home.segments.subheading')}</p>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {segments.map((s) => (
          <SegmentCard
            href={pathFor(s.data.segmentKey, lang)}
            title={s.data.title}
            excerpt={s.data.excerpt}
            image={s.data.heroImage}
            imageAlt={s.data.heroImageAlt}
            ctaLabel={t('common.exploreSegment')}
          />
        ))}
      </div>
    </div>
  </section>

  <StatBlock stats={stats} heading={t('home.stats.heading')} />

  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      <h2 class="font-heading text-3xl font-bold text-brand-navy-950">{t('home.why.heading')}</h2>
      <p class="mt-3 max-w-2xl text-neutral-600">
        FlotLife Nordic pairs FlotLife's technology with Nordic operating experience — we'd
        rather be a long-term technical partner than a one-time equipment supplier.
      </p>
      <div class="mt-10 grid gap-10 sm:grid-cols-3">
        <div>
          <h3 class="font-heading text-lg font-bold text-brand-navy-950">One partner, full responsibility</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">Design, equipment, installation and automation — from a single team, not a chain of subcontractors.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-brand-navy-950">Proven in the field, not just on paper</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">FlotLife's dewatering units are already running on municipal, food-industry and aquaculture sludge across the Nordics — including a cod farm in Norway.</p>
        </div>
        <div>
          <h3 class="font-heading text-lg font-bold text-brand-navy-950">Waste that becomes a resource</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">Our sludge dewatering doesn't just reduce disposal costs — it turns a byproduct into something worth collecting.</p>
        </div>
      </div>
    </div>
  </section>

  <CTA heading={t('home.cta.heading')} body={t('home.cta.body')} ctaLabel={t('common.contactUs')} ctaHref={pathFor('contact', lang)} />
</BaseLayout>
