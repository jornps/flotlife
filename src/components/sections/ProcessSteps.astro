---
interface Step {
  label: string;
  description: string;
}

interface Props {
  heading?: string;
  intro?: string;
  steps: Step[];
}

const { heading, intro, steps } = Astro.props;
---

<section class="bg-brand-navy-950">
  <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
    {heading && <h2 class="font-heading text-3xl font-bold text-white">{heading}</h2>}
    {intro && <p class="mt-3 max-w-2xl text-white/70">{intro}</p>}
    <ol class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step, i) => (
        <li class="rounded-2xl border border-white/10 bg-white/5 p-6">
          <span class="font-heading text-sm font-semibold text-brand-cyan-400">0{i + 1}</span>
          <h3 class="mt-3 font-heading text-lg font-bold text-white">{step.label}</h3>
          <p class="mt-2 text-sm leading-relaxed text-white/70">{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
