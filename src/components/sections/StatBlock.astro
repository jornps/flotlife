---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  heading?: string;
}

const { stats, heading } = Astro.props;
---

{stats.length > 0 && (
  <section class="bg-white">
    <div class="mx-auto max-w-7xl px-6 py-16 lg:px-8">
      {heading && <h2 class="font-heading text-2xl font-bold text-brand-navy-950">{heading}</h2>}
      <dl class="mt-8 grid grid-cols-2 gap-8 sm:grid-cols-4">
        {stats.map((stat) => (
          <div>
            <dt class="sr-only">{stat.label}</dt>
            <dd class="font-heading text-3xl font-bold text-brand-navy-900 sm:text-4xl">{stat.value}</dd>
            <p class="mt-2 text-sm text-neutral-600">{stat.label}</p>
          </div>
        ))}
      </dl>
    </div>
  </section>
)}
