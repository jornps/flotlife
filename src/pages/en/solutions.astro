---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import SolutionCard from '../../components/sections/SolutionCard.astro';
import CTA from '../../components/sections/CTA.astro';
import HowItWorks from '../../components/sections/HowItWorks.astro';
import TechPlatform from '../../components/sections/TechPlatform.astro';
import { pathFor } from '../../i18n/routes';
import { useTranslations } from '../../i18n/utils';
import heroImage from '../../assets/solutions/fds-320-installation.jpg';

const lang = 'en';
const t = useTranslations(lang);
const solutions = (await getCollection('solutions', (s) => s.data.lang === lang)).sort(
  (a, b) => a.data.order - b.data.order,
);

const segmentLabels: Record<string, string> = {
  havbruk: t('nav.havbruk'),
  industri: t('nav.industri'),
  kommunal: t('nav.kommunal'),
  maritim: t('nav.maritim'),
};

const processStepLabels: Record<string, string> = {
  daf: 'Capture & Separate',
  'screw-press': 'Dewater',
  'biological-treatment': 'Polish',
  'containerized-plant': 'Full line',
};
---

<BaseLayout lang={lang} pageKey="solutions" title="Solutions | FlotLife Nordic" description="Dissolved air flotation, sludge dewatering, biological treatment and containerized plants — the four core technologies behind FlotLife Nordic.">
  <Hero title={t('solutions.hero.title')} subtitle={t('solutions.hero.subtitle')} image={heroImage} imageAlt="FDS sludge dewatering unit installed at an industrial treatment facility" />

  <section style="background:#fff;padding:56px 0 0;">
    <div style="max-width:1200px;margin:0 auto;padding:0 40px;">
      <p style="font-size:18px;color:#5b6b78;line-height:1.7;max-width:720px;">
        FlotLife Nordic doesn't start with equipment — we start with your water. Once we know
        what's in it, what you need to discharge, and what space you have, we assemble a
        treatment line from the four core technologies below. Most sites need two or three of
        them. Some need all four.
      </p>
    </div>
  </section>

  <TechPlatform lang={lang} />

  <HowItWorks lang={lang} />

  <section class="bg-neutral-50">
    <div class="mx-auto max-w-5xl space-y-6 px-6 py-16 lg:px-8">
      {solutions.map((s) => (
        <SolutionCard
          title={s.data.title}
          excerpt={s.data.excerpt}
          image={s.data.image}
          imageAlt={s.data.imageAlt}
          usedInLabel={t('solutions.forSegments')}
          usedIn={s.data.applicableSegments.map((key) => segmentLabels[key])}
          processStep={processStepLabels[s.data.solutionKey]}
          technicalDetails={s.data.technicalDetails}
          detailsLabel={t('solutions.technicalDetails')}
        />
      ))}
    </div>
  </section>

  <CTA heading={t('segment.cta.heading')} ctaLabel={t('common.contactUs')} ctaHref={pathFor('contact', lang)} />
</BaseLayout>
