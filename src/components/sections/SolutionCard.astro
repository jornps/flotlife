---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import { marked } from 'marked';

interface Props {
  title: string;
  excerpt: string;
  image?: ImageMetadata;
  imageAlt?: string;
  usedInLabel?: string;
  usedIn?: string[];
  processStep?: string;
  technicalDetails?: string;
  detailsLabel?: string;
}

const { title, excerpt, image, imageAlt, usedInLabel, usedIn = [], processStep, technicalDetails, detailsLabel = 'Technical specifications' } = Astro.props;
const detailsHtml = technicalDetails ? await marked.parse(technicalDetails) : '';
---

<article class="rounded-2xl border border-neutral-200 bg-white shadow-sm overflow-hidden">
  <div class="grid sm:grid-cols-5 sm:items-stretch">
    <div class="sm:col-span-2">
      <div class="aspect-[4/3] sm:aspect-auto sm:h-full overflow-hidden bg-brand-navy-900">
        {image && <Image src={image} alt={imageAlt ?? ''} widths={[400, 800]} sizes="(min-width:640px) 40vw, 100vw" class="h-full w-full object-cover" />}
      </div>
    </div>
    <div class="sm:col-span-3 p-6 flex flex-col">
      {processStep && (
        <span class="inline-block self-start rounded-full bg-brand-green-200 px-3 py-1 text-xs font-semibold text-brand-green-700">{processStep}</span>
      )}
      <h3 class="mt-3 font-heading text-xl font-bold text-brand-navy-950">{title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-neutral-600 flex-1">{excerpt}</p>
      {usedIn.length > 0 && (
        <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-neutral-400">
          {usedInLabel} <span class="text-brand-navy-700">{usedIn.join(' · ')}</span>
        </p>
      )}
    </div>
  </div>

  {technicalDetails && (
    <details class="border-t border-neutral-100 group">
      <summary class="flex cursor-pointer select-none items-center justify-between px-6 py-4 text-sm font-semibold text-brand-navy-700 hover:bg-neutral-50 transition-colors list-none">
        <span>{detailsLabel}</span>
        <svg class="h-4 w-4 shrink-0 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-6 pb-6 pt-2 prose prose-sm prose-neutral max-w-none prose-headings:font-heading prose-headings:text-brand-navy-900 prose-strong:text-brand-navy-800">
        <Fragment set:html={detailsHtml} />
      </div>
    </details>
  )}
</article>
