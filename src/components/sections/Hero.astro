---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import Button from '../ui/Button.astro';

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { eyebrow, title, subtitle, ctaLabel, ctaHref, ctaSecondaryLabel, ctaSecondaryHref, image, imageAlt } =
  Astro.props;
---

<section class="relative overflow-hidden bg-brand-navy-950 text-white">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,_var(--color-brand-navy-700),_transparent_60%)]"></div>
  <div class="relative mx-auto grid max-w-7xl gap-12 px-6 py-20 lg:grid-cols-2 lg:items-center lg:px-8 lg:py-28">
    <div>
      {eyebrow && <p class="text-sm font-semibold uppercase tracking-widest text-brand-cyan-400">{eyebrow}</p>}
      <h1 class="mt-4 font-heading text-4xl font-bold leading-tight sm:text-5xl">{title}</h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">{subtitle}</p>
      {(ctaLabel || ctaSecondaryLabel) && (
        <div class="mt-9 flex flex-wrap gap-4">
          {ctaLabel && ctaHref && <Button href={ctaHref}>{ctaLabel}</Button>}
          {ctaSecondaryLabel && ctaSecondaryHref && (
            <Button href={ctaSecondaryHref} variant="ghost">{ctaSecondaryLabel}</Button>
          )}
        </div>
      )}
    </div>
    {image && (
      <div class="relative">
        <div class="overflow-hidden rounded-2xl shadow-2xl ring-1 ring-white/10">
          <Image src={image} alt={imageAlt ?? ''} widths={[400, 800, 1200]} sizes="(min-width: 1024px) 50vw, 100vw" class="h-full w-full object-cover" />
        </div>
      </div>
    )}
  </div>
</section>
